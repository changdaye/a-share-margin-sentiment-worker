{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "a-share-margin-sentiment-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "account_id": "905ebcafff7f6fb7c62a6226887da305",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "0 9 * * *"
    ]
  },
  "ai": {
    "binding": "AI"
  },
  "kv_namespaces": [
    {
      "binding": "RUNTIME_KV",
      "id": "2821fa8bc90f421aaf8d1a8705f695c5",
      "preview_id": "2821fa8bc90f421aaf8d1a8705f695c5"
    }
  ],
  "d1_databases": [
    {
      "binding": "WATCHER_DB",
      "database_name": "a-share-margin-sentiment-worker",
      "database_id": "7549ecf4-d3ec-4ff8-bfe1-6496ffab92bd",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "RUN_HOUR_LOCAL": "17",
    "RUN_MINUTE_LOCAL": "0",
    "MARKET_TIMEZONE": "Asia/Shanghai",
    "WORKER_PUBLIC_BASE_URL": "https://a-share-margin-sentiment-worker.wanggejiancai822.workers.dev",
    "HEARTBEAT_INTERVAL_HOURS": "24",
    "REQUEST_TIMEOUT_MS": "15000",
    "LOOKBACK_DAYS": "250",
    "ALERT_COOLDOWN_HOURS": "24",
    "FAILURE_ALERT_THRESHOLD": "1",
    "FAILURE_ALERT_COOLDOWN_MINUTES": "180",
    "LLM_MODEL": "gpt-5.4"
  }
}
